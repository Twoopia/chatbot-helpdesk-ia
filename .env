# IA Provider: "anthropic" ou "openai"
AI_PROVIDER=anthropic

# Chaves de API (configure apenas a do provedor escolhido)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Modelo de IA
# Anthropic: claude-sonnet-4-6 | claude-opus-4-7 | claude-haiku-4-5-20251001
# OpenAI: gpt-4o | gpt-4o-mini | gpt-3.5-turbo
AI_MODEL=claude-sonnet-4-6

# Configurações do modelo
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7

# Configurações da aplicação
APP_NAME=Help Desk IA
APP_VERSION=1.0.0
MAX_HISTORY_PER_SESSION=50
SESSION_TIMEOUT_HOURS=24

# Logs
LOG_LEVEL=INFO
LOG_DIR=logs

# CORS (use * para desenvolvimento, defina domínios específicos em produção)
ALLOWED_ORIGINS=*

# Prompt do sistema (opcional - sobrescreve o padrão)
# SYSTEM_PROMPT=Você é um assistente de TI especializado...
